    <content type="html"><![CDATA[<p>输入特殊符号：</p>

<table>
<thead>
<tr>
<th align="left">描述(Desc)     </th>
<th align="left"> 按键（Key）  </th>
<th align="left">符号(Sign)</th>
</tr>
</thead>
<tbody>
<tr>
<td align="left">版权符号:      </td>
<td align="left"> Option + G     </td>
<td align="left"> © </td>
</tr>
<tr>
<td align="left">人民币符号:    </td>
<td align="left"> Option + Y   </td>
<td align="left"> ¥ </td>
</tr>
<tr>
<td align="left">商标符号:      </td>
<td align="left"> Option + 2   </td>
<td align="left"> ™ </td>
</tr>
<tr>
